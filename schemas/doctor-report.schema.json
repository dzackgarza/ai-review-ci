{
  "$defs": {
    "BranchProtectionObservation": {
      "additionalProperties": false,
      "properties": {
        "required_contexts": {
          "items": {
            "type": "string"
          },
          "title": "Required Contexts",
          "type": "array"
        },
        "observed_contexts": {
          "items": {
            "type": "string"
          },
          "title": "Observed Contexts",
          "type": "array"
        },
        "observed_state": {
          "enum": [
            "not_applicable",
            "compliant",
            "missing",
            "missing_contexts",
            "unverifiable"
          ],
          "title": "Observed State",
          "type": "string"
        },
        "evidence": {
          "title": "Evidence",
          "type": "string"
        }
      },
      "required": [
        "required_contexts",
        "observed_contexts",
        "observed_state",
        "evidence"
      ],
      "title": "BranchProtectionObservation",
      "type": "object"
    },
    "DeclarationObservation": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        },
        "manifest": {
          "anyOf": [
            {
              "$ref": "#/$defs/QcManifest"
            },
            {
              "$ref": "#/$defs/MissingManifest"
            }
          ],
          "title": "Manifest"
        }
      },
      "required": [
        "path",
        "sha256",
        "manifest"
      ],
      "title": "DeclarationObservation",
      "type": "object"
    },
    "DelegationCommandObservation": {
      "additionalProperties": false,
      "properties": {
        "present": {
          "title": "Present",
          "type": "boolean"
        },
        "command": {
          "title": "Command",
          "type": "string"
        },
        "delegates_to_global_qc": {
          "title": "Delegates To Global Qc",
          "type": "boolean"
        },
        "caller_root_preserved": {
          "title": "Caller Root Preserved",
          "type": "boolean"
        }
      },
      "required": [
        "present",
        "command",
        "delegates_to_global_qc",
        "caller_root_preserved"
      ],
      "title": "DelegationCommandObservation",
      "type": "object"
    },
    "DelegationObservation": {
      "additionalProperties": false,
      "properties": {
        "required_justfile": {
          "title": "Required Justfile",
          "type": "string"
        },
        "observed": {
          "$ref": "#/$defs/DelegationCommandObservation"
        }
      },
      "required": [
        "required_justfile",
        "observed"
      ],
      "title": "DelegationObservation",
      "type": "object"
    },
    "DoctorFinding": {
      "additionalProperties": false,
      "properties": {
        "severity": {
          "enum": [
            "error",
            "warning"
          ],
          "title": "Severity",
          "type": "string"
        },
        "surface": {
          "enum": [
            "manifest",
            "profile",
            "workflow",
            "workflow_ref",
            "justfile_delegation",
            "justfile_conformance",
            "branch_protection"
          ],
          "title": "Surface",
          "type": "string"
        },
        "evidence": {
          "title": "Evidence",
          "type": "string"
        },
        "remediation_commands": {
          "items": {
            "type": "string"
          },
          "title": "Remediation Commands",
          "type": "array"
        }
      },
      "required": [
        "severity",
        "surface",
        "evidence",
        "remediation_commands"
      ],
      "title": "DoctorFinding",
      "type": "object"
    },
    "ManifestException": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "surface": {
          "enum": [
            "manifest",
            "profile",
            "workflow",
            "workflow_ref",
            "justfile_delegation",
            "justfile_conformance",
            "branch_protection"
          ],
          "title": "Surface",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "active": {
          "title": "Active",
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "surface",
        "reason",
        "active"
      ],
      "title": "ManifestException",
      "type": "object"
    },
    "MissingManifest": {
      "additionalProperties": false,
      "properties": {
        "present": {
          "const": false,
          "title": "Present",
          "type": "boolean"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "present",
        "reason"
      ],
      "title": "MissingManifest",
      "type": "object"
    },
    "ProfileProofObservation": {
      "additionalProperties": false,
      "properties": {
        "profile": {
          "enum": [
            "python",
            "bun",
            "bun-playwright",
            "rust",
            "sage"
          ],
          "title": "Profile",
          "type": "string"
        },
        "required_paths": {
          "items": {
            "type": "string"
          },
          "title": "Required Paths",
          "type": "array"
        },
        "missing_paths": {
          "items": {
            "type": "string"
          },
          "title": "Missing Paths",
          "type": "array"
        }
      },
      "required": [
        "profile",
        "required_paths",
        "missing_paths"
      ],
      "title": "ProfileProofObservation",
      "type": "object"
    },
    "QcManifest": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "profile": {
          "enum": [
            "python",
            "bun",
            "bun-playwright",
            "rust",
            "sage"
          ],
          "title": "Profile",
          "type": "string"
        },
        "installed_ref": {
          "minLength": 1,
          "title": "Installed Ref",
          "type": "string"
        },
        "release_channel": {
          "minLength": 1,
          "title": "Release Channel",
          "type": "string"
        },
        "workflow_template_version": {
          "const": 1,
          "title": "Workflow Template Version",
          "type": "integer"
        },
        "local_delegation": {
          "const": "global-justfile",
          "title": "Local Delegation",
          "type": "string"
        },
        "default_branch": {
          "minLength": 1,
          "title": "Default Branch",
          "type": "string"
        },
        "exceptions": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ManifestException"
          },
          "title": "Exceptions",
          "type": "array"
        }
      },
      "required": [
        "schema_version",
        "profile",
        "installed_ref",
        "release_channel",
        "workflow_template_version",
        "local_delegation",
        "default_branch"
      ],
      "title": "QcManifest",
      "type": "object"
    },
