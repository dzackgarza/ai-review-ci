    "tool_version",
    "target",
    "declaration",
    "declaration_hash",
    "declared_profile",
    "effective_profile",
    "workflow_refs",
    "justfile_delegation",
    "branch_protection",
    "profile_proof_requirements",
    "findings",
    "invalidation_inputs",
    "installation_state",
    "global_status",
    "exceptions"
