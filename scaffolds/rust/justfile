# ai-review-ci Rust QC delegation justfile.
# The central implementation lives in ~/ai-review-ci/justfiles/rust.just.
# Public recipes delegate to that central justfile while preserving this repo as the caller root.

# List available recipes.
default:
    @just --list

# Run commit-tier Rust QC through the central implementation.
test:
    @just -d . -f ~/ai-review-ci/justfiles/rust.just test

# Run push-tier Rust QC through the central implementation.
test-ci:
    @just -d . -f ~/ai-review-ci/justfiles/rust.just test-ci
