# ai-review-ci docs-and-configs QC delegation justfile.
# The central implementation lives in ~/ai-review-ci/justfiles/docs-and-configs.just.
# Public recipes preserve this repository as the caller root.

# ai-review-ci contract variables consumed by doctor and workflow installers.
ai_review_ci_schema_version := "1"
ai_review_ci_profile := "docs-and-configs"
