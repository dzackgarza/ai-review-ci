#!/bin/bash
# Validates the candidate report at the fixed path within REVIEWER_REPO.
# On success: copies to artifact path and exits 0.
# On failure: prints errors and exits non-zero.
# The agent fixes the same file and re-runs this script.

set -euo pipefail

REVIEWER_REPO="${REVIEWER_REPO:?REVIEWER_REPO is required}"
CONTROL_REPO="${CONTROL_REPO:?CONTROL_REPO is required}"

CANDIDATE="$REVIEWER_REPO/.agents/review-runner/candidates/submitted.json"
PRIVATE_PROJECT="/opt/ai-review/private"
ARTIFACT="$REVIEWER_REPO/.review-report-artifact.json"

if [ "${1:-}" = "--help" ]; then
    cat <<'HELP'
submit-candidate — validate and submit a review report

Usage:
  submit-candidate            # validate and submit (default)
  submit-candidate --help     # print this message

Write the report JSON to .agents/review-runner/candidates/submitted.json,
then run this script with no arguments.

The script validates the report against pydantic models.
On success, exits 0. On failure, prints errors with
FIX: guidance and exits non-zero — fix the same file and re-run.

Your report contains analysis only — run provenance (commit, ref) is
attached by the CI pipeline, not by you.

Every path (review_scope, location.path, evidence[].path) must be a real
file in the repository, relative to the repo root, and every line range
must lie within the file.

Do not include "score" or "report" fields — they are rejected.

The structural example below shows the expected JSON shape.
Validator error messages teach the field-level constraints — do not read the
validator script directly; it is root-owned and not available to the agent.

Example (general report — slop uses SlopFinding fields):
HELP
    echo ""
    echo "Full JSON Schema (auto-generated from pydantic models):"
    echo ""
    if [ -z "${REPORT_TYPE:-}" ]; then
        echo "Error: REPORT_TYPE env var must be set (general or slop)" >&2
        exit 1
    fi
    uv run --project "$PRIVATE_PROJECT" ai-review-ci report-schema "$REPORT_TYPE"
    exit 0
fi

if ! [ -f "$CANDIDATE" ]; then
    echo "ERROR: No report found at $CANDIDATE"
    echo "Write your report to $CANDIDATE first, then run this script."
    exit 1
fi

if [ -z "${REPORT_TYPE:-}" ]; then
    echo "ERROR: REPORT_TYPE env var must be set (general or slop)" >&2
    exit 1
fi

# Validate from the control repo: path-existence checks must run against
# the real checkout, never the reviewer's writable copy.
cd "$CONTROL_REPO"

if uv run --project "$PRIVATE_PROJECT" ai-review-ci validate-report "$CANDIDATE" \
      --report-type "$REPORT_TYPE" --output "$ARTIFACT" 2>&1; then
    uv run --project "$PRIVATE_PROJECT" ai-review-ci report-metadata "$ARTIFACT"
    echo "Report validated and submitted to $ARTIFACT"
    exit 0
fi
exit 1
