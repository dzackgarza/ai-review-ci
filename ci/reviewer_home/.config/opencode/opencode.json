{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["cc-safety-net@latest"],
  "model": "opencode/deepseek-v4-flash-free",
  "permission": {
    "webfetch": "deny",
    "bash": {
      "*": "allow",
      "git *": "deny",
      "sudo *": "deny",
      "opencode *": "deny",
      "*/opt/ai-review*": "deny",
      "*/home/reviewer/.review/*": "deny"
    }
  }
}
