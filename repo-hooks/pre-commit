#!/usr/bin/env sh
set -e
repo_root="$(git rev-parse --show-toplevel)"
hook_file="$(readlink -f "$0")"
hook_repo="$(CDPATH= cd -- "$(dirname -- "$hook_file")/.." && pwd -P)"
repo_common_dir="$(git -C "$repo_root" rev-parse --git-common-dir)"
hook_common_dir="$(git -C "$hook_repo" rev-parse --git-common-dir)"
case "$repo_common_dir" in
  /*) ;;
  *) repo_common_dir="$repo_root/$repo_common_dir" ;;
esac
case "$hook_common_dir" in
  /*) ;;
  *) hook_common_dir="$hook_repo/$hook_common_dir" ;;
esac
repo_common_dir="$(CDPATH= cd -- "$repo_common_dir" && pwd -P)"
hook_common_dir="$(CDPATH= cd -- "$hook_common_dir" && pwd -P)"
if [ "$repo_common_dir" = "$hook_common_dir" ]; then
  exit 0
fi
exec just test
