{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "files": {
    "includes": [
      "**",
      "!tsconfig.json",
      "!**/tsconfig.json",
      "!**/node_modules/**",
      "!**/.venv/**",
      "!**/__pycache__/**",
      "!**/dist/**",
      "!**/build/**",
      "!**/coverage/**",
      "!**/_ci-support/**",
      "!**/codeql-db/**",
      "!**/@girs/**",
      "!**/__stubs__/**",
      "!**/external/**",
      "!**/target/**",
      "!**/*.bak/**",
      "!**/.git/**",
      "!**/.next/**",
      "!**/.lake/**",
      "!**/.worktrees/**",
      "!**/vendor/**",
      "!**/third_party/**",
      "!**/venv/**"
    ]
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": false
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
