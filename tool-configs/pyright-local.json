{
  "typeCheckingMode": "strict",
  "pythonVersion": "3.14",
  "pythonPlatform": "Linux",
  "exclude": [
    "**/node_modules",
    "**/.venv",
    "**/__pycache__",
    "**/dist",
    "**/build",
    "**/coverage",
    "**/_ci-support",
    "**/codeql-db",
    "**/@girs",
    "**/__stubs__",
    "**/external",
    "**/target",
    "**/*.bak",
    "**/.git",
    "**/.next",
    "**/.lake",
    "**/.worktrees",
    "**/vendor",
    "**/third_party",
    "**/venv"
  ]
}
