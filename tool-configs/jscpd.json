{
  "threshold": 10,
  "reporters": [
    "console"
  ],
  "ignore": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/__tests__/**",
    "**/coverage.xml",
    "**/codeql-report.sarif",
    "**/node_modules/**",
    "**/.venv/**",
    "**/__pycache__/**",
