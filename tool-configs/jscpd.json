{
  "threshold": 10,
  "reporters": [
    "console"
  ],
  "ignore": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/__tests__/**",
    "**/coverage.xml",
    "**/codeql-report.sarif",
    "**/tests/fixtures/slop-torture/**",
    "**/tests/fixtures/ast-grep/**",
    "**/node_modules/**",
    "**/.venv/**",
    "**/.pytest_cache/**",
    "**/.import_linter_cache/**",
    "**/__pycache__/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/_ci-support/**",
    "**/codeql-db/**",
    "**/tool-artifacts/models/**",
    "**/@girs/**",
    "**/__stubs__/**",
    "**/external/**",
    "**/target/**",
    "**/*.bak/**",
    "**/.git/**",
    "**/.next/**",
    "**/.lake/**",
    "**/.worktrees/**",
    "**/.claude/worktrees/**",
    "**/vendor/**",
    "**/third_party/**",
    "**/venv/**",
    "**/scripts/**",
    "**/notebooks/**"
  ],
  "absolute": true,
  "gitignore": true
}
