{
  "entry": [
    "src/index.ts",
    "src/**/*.ts",
    "app.tsx",
    "lib/**/*.ts"
  ],
  "project": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "widget/**/*.tsx",
    "services/**/*.ts",
    "app.tsx"
  ],
  "ignore": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/__tests__/**",
    "**/env.d.ts",
    "**/*.tsx",
    "**/node_modules/**",
    "**/.venv/**",
    "**/__pycache__/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/_ci-support/**",
    "**/codeql-db/**",
    "**/@girs/**",
    "**/__stubs__/**",
    "**/external/**",
    "**/target/**",
    "**/*.bak/**",
    "**/.git/**",
    "**/.next/**",
    "**/.lake/**",
    "**/.worktrees/**",
    "**/vendor/**",
    "**/third_party/**",
    "**/venv/**"
  ],
  "ignoreDependencies": [
    "gi",
    "@girs",
    "@logtape/logtape",
    "@ags/shared",
    "ags"
  ],
  "ignoreBinaries": [
    "ags"
  ],
  "ignoreExportsUsedInFile": true
}
