{
  "entry": [
    "src/index.ts",
    "src/**/*.ts",
    "app.tsx",
    "lib/**/*.ts",
    "src/**/*.css",
    "app.css",
    "index.css",
    "src/**/*.tsx",
    "extension/**/*.{js,ts,tsx}",
    "extension/**/*.css"
  ],
  "project": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "widget/**/*.tsx",
    "services/**/*.ts",
    "app.tsx",
    "src/**/*.css",
    "app.css",
    "index.css",
    "extension/**/*.{js,ts,tsx}",
    "extension/**/*.css"
  ],
  "ignore": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/__tests__/**",
    "**/env.d.ts",
    "**/node_modules/**",
    "**/.venv/**",
    "**/.pytest_cache/**",
    "**/.import_linter_cache/**",
    "**/__pycache__/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/_ci-support/**",
    "**/codeql-db/**",
    "**/tool-artifacts/models/**",
    "**/@girs/**",
    "**/__stubs__/**",
    "**/external/**",
    "**/target/**",
    "**/*.bak/**",
    "**/.git/**",
    "**/.next/**",
    "**/.lake/**",
    "**/.worktrees/**",
    "**/vendor/**",
    "**/third_party/**",
    "**/venv/**"
  ],
  "ignoreDependencies": ["gi", "@girs", "@logtape/logtape", "@ags/shared", "ags", "@tailwindcss/cli", "@tailwindcss/typography", "tailwindcss", "tw-animate-css"],
  "ignoreBinaries": ["ags", "xdg-open", "direnv"],
  "ignoreExportsUsedInFile": true,
  "ignoreUnresolved": ["./vendor/backend.js"]
}
